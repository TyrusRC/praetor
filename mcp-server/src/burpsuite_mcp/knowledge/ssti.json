    "jinja2": {
      "description": "Server-Side Template Injection probes for Jinja2 (Flask/Django Python stacks)",
      "tech_match": [
        "Flask",
        "Django",
        "Python"
      ],
      "param_match": [
        "name",
        "template",
        "msg",
        "text",
        "title",
        "comment",
        "input",
        "value",
        "q"
      ],
      "probes": [
        {
          "payload": "{{7*7}}",
          "description": "Jinja2 arithmetic evaluation \u2014 response containing 49 confirms template execution",
          "matchers": [
            {
              "type": "word",
              "words": [
                "49"
              ],
              "condition": "or"
            },
            {
              "type": "not_word",
              "words": [
                "$49",
                "49 ",
                " 49.",
                "\"49\"",
                "v49",
                "#49"
              ]
            }
          ],
          "severity": "high",
          "confidence_boost": 65,
          "variables": {}
        },
        {
          "payload": "{{config}}",
          "description": "Jinja2 config dump \u2014 reveals SECRET_KEY and DEBUG mode",
          "matchers": [
            {
              "type": "word",
              "words": [
                "SECRET_KEY",
                "DEBUG"
              ],
              "condition": "or"
            }
          ],
          "severity": "critical",
          "confidence_boost": 80,
          "variables": {}
        }
      ]
    },
