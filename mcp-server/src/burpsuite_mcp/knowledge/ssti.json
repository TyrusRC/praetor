{
  "category": "ssti",
  "contexts": {
    "jinja2": {
      "description": "Server-Side Template Injection probes for Jinja2 (Flask/Django Python stacks)",
      "tech_match": ["Flask", "Django", "Python"],
      "param_match": ["name", "template", "msg", "text", "title", "comment", "input", "value", "q"],
      "probes": [
        {
          "payload": "{{7*7}}",
          "description": "Jinja2 arithmetic evaluation — response containing 49 confirms template execution",
          "matchers": [
            {"type": "word", "words": ["49"], "condition": "or"}
          ],
          "severity": "high",
          "confidence_boost": 65,
          "variables": {}
        },
        {
          "payload": "{{config}}",
          "description": "Jinja2 config dump — reveals SECRET_KEY and DEBUG mode",
          "matchers": [
            {"type": "word", "words": ["SECRET_KEY", "DEBUG"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 80,
          "variables": {}
        }
      ]
    },
    "twig": {
