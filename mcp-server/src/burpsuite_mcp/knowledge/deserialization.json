    "java_commons_collections": {
      "description": "Java Commons Collections gadget chain detection — probes for CC1-CC7 deserialization gadgets via error message fingerprinting",
      "tech_match": ["Java", "Tomcat", "JBoss", "WebLogic", "Spring"],
      "param_match": ["data", "object", "payload", "token", "session", "viewstate", "state"],
      "probes": [
        {
          "payload": "rO0ABXNyADJvcmcuYXBhY2hlLmNvbW1vbnMuY29sbGVjdGlvbnMubWFwLkxhenlNYXBn",
          "description": "Commons Collections LazyMap gadget (truncated base64) — ClassNotFoundException or InvokerTransformer in error confirms CC library is on classpath and deserialization occurs",
          "matchers": [
            {"type": "status", "status": [500]},
            {"type": "word", "words": ["InvokerTransformer", "LazyMap", "commons.collections", "ClassNotFoundException", "TransformedMap"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 65
