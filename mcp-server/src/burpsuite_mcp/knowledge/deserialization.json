        {
          "payload": "rO0ABXNyAC5qYXZheC5tYW5hZ2VtZW50LkJhZEF0dHJpYnV0ZVZhbHVlRXhwRXhjZXB0aW9u",
          "description": "Java BadAttributeValueExpException gadget (base64) — triggers toString() chain; error mentioning BadAttributeValueExpException confirms deserialization path",
          "matchers": [
            {"type": "status", "status": [500]},
            {"type": "word", "words": ["BadAttributeValueExpException", "ObjectInputStream", "readObject", "deserialization"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 55
