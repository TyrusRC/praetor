      "probes": [
        {
          "payload": "%{1337*1338}",
          "description": "OGNL arithmetic \u2014 if 1788906 appears in response, OGNL eval confirmed",
          "matchers": [
            {
              "type": "word",
              "words": [
                "1788906"
              ],
              "condition": "or"
            }
          ],
          "severity": "critical",
          "confidence_boost": 70
