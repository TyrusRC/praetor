    "dns_rebinding_advanced": {
      "description": "DNS rebinding 2024+ variants. Classic A-record TTL-0 swap is well-known; new vectors abuse SVCB/HTTPS records (RFC 9460) and WebRTC ICE candidate disclosure.",
      "tech_match": [],
      "param_match": [
        "url",
        "host",
        "callback"
      ],
      "probes": [
        {
          "payload": "http://attacker-rebind.collaborator.example/",
          "description": "[Manual] DNS rebind: attacker domain returns public IP first, 127.0.0.1 / 169.254.169.254 second. Apps that re-resolve between TOCTOU validation and fetch hit internal target.",
          "matchers": [
            {
              "type": "word",
              "any": [
                "ami-id",
                "instance-identity",
                "iam"
              ]
            }
          ],
          "severity": "critical",
          "confidence_boost": 60,
          "variables": {
            "manual_chain": true,
            "COLLAB_REQUIRED": true
          }
        },
        {
          "payload": "{{baseline}}",
          "description": "[Manual] SVCB / HTTPS resource records (RFC 9460): attacker DNS returns SVCB pointing at internal IP via 'ipv4hint'/'ipv6hint'. HTTP clients that prefer SVCB without re-validating get redirected internally.",
          "matchers": [
            {
              "type": "word",
              "any": [
                "169.254",
                "127.0.0.1",
                "metadata"
              ]
            }
          ],
          "severity": "high",
          "confidence_boost": 50,
