    "blind_time": {
      "description": "Time-based blind SQL injection with differential timing",
      "tech_match": [],
      "param_match": ["id", "uid", "pid", "num", "page", "idx", "index", "user_id", "cat"],
      "probes": [
        {
          "payload": "{{baseline}}; WAITFOR DELAY '0:0:3'--",
