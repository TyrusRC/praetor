          "matchers": [
            {
              "type": "status",
              "status": [
                200
              ]
            },
            {
              "type": "length_diff",
              "min_diff": 50
            }
          ],
          "severity": "high",
          "confidence_boost": 35,
          "variables": {}
        },
        {
          "payload": "{{baseline}} UNION SELECT NULL,NULL,NULL-- -",
          "description": "Three-column UNION probe \u2014 status 200 or length diff indicates correct column count",
          "matchers": [
            {
              "type": "status",
              "status": [
                200
              ]
            },
            {
              "type": "length_diff",
              "min_diff": 50
            }
          ],
          "severity": "high",
          "confidence_boost": 35,
          "variables": {}
