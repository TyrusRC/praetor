              "contains": ""
            },
            {
              "type": "header",
              "name": "Age",
              "contains": ""
            },
            {
              "type": "header",
              "name": "CF-Cache-Status",
              "contains": ""
            }
          ],
          "severity": "high",
          "confidence_boost": 55
