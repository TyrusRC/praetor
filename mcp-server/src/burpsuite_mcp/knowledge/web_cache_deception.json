        "varnish",
        "akamai",
        "cloudflare"
      ],
      "param_match": [],
      "probes": [
        {
          "payload": "/api/me%2F..%2Fstatic.css",
          "description": "Encoded slash interpreted differently by CDN vs origin",
          "matchers": [
            {
              "type": "header_added",
              "headers": [
