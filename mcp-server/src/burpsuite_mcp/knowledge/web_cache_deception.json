    "static_suffix_cache_poisoning": {
      "description": "Web cache deception via static-suffix append. /endpoint/profile.css fetched as auth user — backend serves dynamic profile, cache stores under .css key. Subsequent unauth GET to /endpoint/profile.css serves cached PII. Active in W13.",
      "tech_match": [
        "Varnish",
        "Cloudflare",
        "Akamai",
        "Fastly",
        "CloudFront",
        "Nginx",
        "CDN"
      ],
      "param_match": [],
      "probes": [
        {
          "payload": "{{baseline}}",
          "description": "Append .css suffix to authenticated endpoint; 200 + cache header + user-data word = cache deception.",
          "matchers": [
            {
              "type": "status",
              "status": [
                200
              ]
            },
            {
              "type": "word",
              "words": [
                "username",
                "email",
                "account",
                "profile",
                "session",
                "token"
              ],
              "condition": "or"
            },
            {
              "type": "header",
              "name": "Cache-Control",
              "contains": "public"
            }
          ],
          "severity": "high",
          "confidence_boost": 60,
          "variables": {
            "path_suffix": ".css",
            "manual_chain": true
          }
        },
        {
          "payload": "{{baseline}}",
          "description": "CDN cache-status header explicitly indicates cacheable hit + body has user data → deception confirmed.",
          "matchers": [
            {
              "type": "status",
              "status": [
                200
              ]
            },
            {
              "type": "word",
              "words": [
                "username",
                "email",
                "profile",
                "session"
              ],
              "condition": "or"
            },
            {
              "type": "header",
              "name": "X-Cache",
              "contains": "HIT"
            }
          ],
          "severity": "critical",
          "confidence_boost": 70,
          "variables": {
            "manual_chain": true
          }
        }
      ]
    }
