          "matchers": [
            {
              "type": "status",
              "status": [
                200
              ]
            },
            {
              "type": "header",
              "name": "X-Cache",
              "contains": ""
            },
            {
              "type": "header",
              "name": "Age",
              "contains": ""
            },
            {
              "type": "header",
              "name": "CF-Cache-Status",
              "contains": ""
            }
          ],
          "severity": "medium",
          "confidence_boost": 45
        }
      ]
    },
    "static_suffix_cache_poisoning": {
      "description": "Web cache deception via static-suffix append. /endpoint/profile.css fetched as auth user — backend serves dynamic profile, cache stores under .css key. Subsequent unauth GET to /endpoint/profile.css serves cached PII. Active in W13.",
      "tech_match": [
        "Varnish",
        "Cloudflare",
        "Akamai",
        "Fastly",
        "CloudFront",
        "Nginx",
        "CDN"
      ],
      "param_match": [],
      "probes": [
        {
          "payload": "{{baseline}}",
          "description": "Append .css suffix to authenticated endpoint; 200 + cache header + user-data word = cache deception.",
          "matchers": [
            {
              "type": "status",
              "status": [
                200
              ]
            },
            {
              "type": "word",
              "words": [
                "username",
                "email",
                "account",
                "profile",
                "session",
                "token"
              ],
              "condition": "or"
            },
            {
              "type": "header",
              "name": "Cache-Control",
              "contains": "public"
            }
          ],
          "severity": "high",
          "confidence_boost": 60,
          "variables": {
            "path_suffix": ".css",
            "manual_chain": true
          }
        },
        {
          "payload": "{{baseline}}",
          "description": "CDN cache-status header explicitly indicates cacheable hit + body has user data → deception confirmed.",
          "matchers": [
            {
              "type": "status",
              "status": [
                200
              ]
            },
            {
              "type": "word",
              "words": [
                "username",
                "email",
                "profile",
                "session"
              ],
              "condition": "or"
            },
            {
              "type": "header",
              "name": "X-Cache",
              "contains": "HIT"
            }
          ],
          "severity": "critical",
          "confidence_boost": 70,
          "variables": {
            "manual_chain": true
          }
        }
      ]
    },
    "semicolon_path_param": {
      "description": "URL with ;static.css after dynamic path — CDN caches as static, origin treats as dynamic",
      "tech_match": [
        "nginx",
        "varnish",
        "akamai",
        "cloudflare",
        "fastly"
      ],
      "param_match": [],
      "probes": [
        {
          "payload": "/profile/me;foo.css",
          "description": "If origin serves /profile/me content AND CDN caches it as .css → cache deception",
          "matchers": [
            {
              "type": "header_change",
              "headers": [
                "Cache-Control",
                "X-Cache",
                "Age"
              ],
              "condition": "or"
            },
            {
              "type": "word",
              "words": [
                "profile",
                "user",
                "email"
              ],
              "condition": "or"
            }
          ],
          "severity": "high",
          "confidence_boost": 65,
          "variables": {}
        }
      ]
    },
    "encoded_slash_split": {
      "description": "URL-encoded slash splits routing between CDN and origin",
      "tech_match": [
