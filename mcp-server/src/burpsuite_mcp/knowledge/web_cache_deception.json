      "probes": [
        {
          "payload": "/static/../account/me",
          "description": "CDN may collapse /static/../account/me -> /account/me, origin serves under /static/ key",
          "matchers": [
            {
              "type": "header_change",
              "headers": [
                "X-Cache",
                "Age"
              ],
              "condition": "or"
            }
          ],
          "severity": "high",
          "confidence_boost": 55,
          "variables": {}
        }
      ]
    }
  },
  "description": "Web cache deception via static-suffix path confusion. Active in W13: static_suffix_cache_poisoning fires on cacheable response with user data word reflection. Existing path_confusion remains as operator-driven payload set."
