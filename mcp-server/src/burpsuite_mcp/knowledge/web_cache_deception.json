        "varnish",
        "akamai",
        "cloudflare",
        "fastly",
        "aws cloudfront"
      ],
      "param_match": [],
      "probes": [
        {
          "payload": "/api/me#cdn-strip.css",
          "description": "Browser sends full URL; CDN may forward fragment, origin may not -- mismatch leads to cached private content",
          "matchers": [
            {
              "type": "header_change",
              "headers": [
                "X-Cache",
                "Age",
                "Cache-Control"
              ],
              "condition": "or"
            }
          ],
          "severity": "high",
          "confidence_boost": 55,
          "variables": {}
