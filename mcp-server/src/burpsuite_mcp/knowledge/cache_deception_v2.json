  "contexts": {
    "semicolon_path_param": {
      "description": "URL with ;static.css after dynamic path \u2014 CDN caches as static, origin treats as dynamic",
      "tech_match": [
        "nginx",
        "varnish",
        "akamai",
        "cloudflare",
        "fastly"
      ],
      "param_match": [],
      "probes": [
        {
          "payload": "/profile/me;foo.css",
          "description": "If origin serves /profile/me content AND CDN caches it as .css \u2192 cache deception",
          "matchers": [
            {
              "type": "header_change",
              "headers": [
                "Cache-Control",
                "X-Cache",
                "Age"
              ],
              "condition": "or"
            },
            {
              "type": "word",
              "words": [
                "profile",
                "user",
                "email"
              ],
              "condition": "or"
            }
          ],
          "severity": "high",
          "confidence_boost": 65,
          "variables": {}
        }
      ]
    },
