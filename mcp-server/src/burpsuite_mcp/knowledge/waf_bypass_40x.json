          "matchers": [
            {"type": "status", "status": [200, 201, 202]}
          ],
          "severity": "high",
          "confidence_boost": 60
        },
        {
          "payload": "X-HTTP-Method-Override: GET",
          "description": "Method-override header bypasses verb-based ACL",
          "matchers": [
            {"type": "status", "status": [200, 301, 302]}
          ],
          "severity": "high",
          "confidence_boost": 65
