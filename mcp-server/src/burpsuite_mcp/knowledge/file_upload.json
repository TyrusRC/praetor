          "payload": "Upload .php.jpg double extension with PHP content (<?php echo 'PROBE_OK'; ?>)",
          "description": "Double extension bypass \u2014 Apache may execute .php.jpg as PHP with AddHandler",
          "matchers": [
            {
              "type": "status",
              "status": [
                200,
                201
