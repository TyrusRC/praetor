          "matchers": [
            {"type": "status", "status": [200, 201]},
            {"type": "word", "words": ["upload", "success", "file"], "condition": "or"}
          ],
          "severity": "medium",
          "confidence_boost": 30
        },
        {
          "payload": "Upload .htaccess to enable PHP execution in upload directory",
          "description": ".htaccess upload — can reconfigure Apache to execute uploads as PHP",
          "matchers": [
            {"type": "status", "status": [200, 201]},
            {"type": "word", "words": ["upload", "success"], "condition": "or"}
          ],
          "severity": "critical",
          "confidence_boost": 45
        },
        {
          "payload": "Upload oversized file (10MB+) to test size limits",
          "description": "Large file upload — tests for DoS via storage exhaustion or missing size limits",
          "matchers": [
            {"type": "status", "status": [200, 201]},
            {"type": "word", "words": ["upload", "success"], "condition": "or"}
          ],
