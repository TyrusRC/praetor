{
  "category": "websocket",
  "contexts": {
    "cswsh": {
      "description": "Cross-Site WebSocket Hijacking — no Origin validation",
      "tech_match": [],
      "param_match": [],
      "probes": [
        {
          "payload": "{{baseline}}",
          "description": "WebSocket handshake with Origin: https://evil.com — check if 101 returned",
          "matchers": [{"type": "status", "status": [101]}, {"type": "header", "name": "Upgrade", "contains": "websocket"}],
          "severity": "high",
          "confidence_boost": 45
        }
      ]
    },
    "auth_bypass": {
      "description": "WebSocket authentication bypass — missing auth on upgrade",
      "tech_match": [],
      "param_match": [],
      "probes": [
        {
          "payload": "{{baseline}}",
          "description": "WebSocket upgrade without cookies/auth — check if connection accepted",
          "matchers": [{"type": "status", "status": [101]}],
          "severity": "high",
          "confidence_boost": 40
        }
      ]
    },
    "injection": {
      "description": "WebSocket message injection — SQLi/XSS in WS messages",
      "tech_match": [],
      "param_match": [],
      "probes": [
        {
          "payload": "{\"message\":\"test' OR '1'='1\"}",
          "description": "SQLi via WebSocket JSON message",
          "matchers": [{"type": "word", "words": ["sql", "syntax", "error", "unclosed"], "condition": "or"}],
          "severity": "high",
          "confidence_boost": 45
        },
        {
          "payload": "{\"message\":\"<img src=x onerror=alert(1)>\"}",
          "description": "XSS via WebSocket message reflection",
          "matchers": [{"type": "reflection", "check_variants": true}],
          "severity": "high",
          "confidence_boost": 40
        }
      ]
    },
    "message_smuggling": {
      "description": "WebSocket-to-HTTP request tunneling — send HTTP requests inside WS frames to reach internal backends",
      "tech_match": ["WebSocket", "Node.js", "Express", "Nginx"],
      "param_match": [],
      "probes": [
        {
          "payload": "GET /admin HTTP/1.1\r\nHost: internal-api\r\n\r\n",
          "description": "HTTP request inside WebSocket frame — test if backend processes raw HTTP sent via WS",
          "matchers": [{"type": "word", "words": ["admin", "dashboard", "settings"], "condition": "or"}],
          "severity": "high",
          "confidence_boost": 30
        }
      ]
    },
    "proto_pollution": {
      "description": "Prototype pollution via WebSocket JSON messages in Node.js applications",
      "tech_match": ["WebSocket", "Node.js", "Express", "Socket.io"],
      "param_match": [],
      "probes": [
        {
          "payload": "{\"__proto__\":{\"polluted\":\"ws_canary\"}}",
          "description": "Prototype pollution via WS JSON message — check if canary appears in subsequent responses",
          "matchers": [{"type": "word", "words": ["ws_canary"]}],
          "severity": "high",
          "confidence_boost": 40
        }
      ]
    }
  }
}
