# Burp Suite Swiss Knife MCP — Environment Configuration
# Copy this file to .env and adjust values for your setup.

# Burp extension API host
# Default: 127.0.0.1 (localhost — Burp on same machine)
# WSL: set to Windows host IP (run: ip route show default | awk '{print $3}')
BURP_API_HOST=127.0.0.1

# Burp extension API port (must match the port in Burp's Swiss Knife config tab)
BURP_API_PORT=8111

# Request timeout in seconds
# BURP_API_TIMEOUT=30

# Max response body size (chars) before truncation
# BURP_MAX_RESPONSE_SIZE=50000

# Burp proxy listener (for browser, katana, httpx, nuclei — routes traffic through Burp)
# IMPORTANT for WSL: must be the same Windows host IP as BURP_API_HOST
# and Burp's proxy listener must be bound to "All interfaces" (not 127.0.0.1)
BURP_PROXY_HOST=127.0.0.1
BURP_PROXY_PORT=8080
